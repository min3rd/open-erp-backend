# ==========================================
# RabbitMQ Configuration
# ==========================================
# RabbitMQ connection URL (amqp://host:port or amqps://host:port)
RABBITMQ_URL=amqp://localhost:5672

# RabbitMQ authentication
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# Virtual host (default: /)
RABBITMQ_VHOST=/

# Connection settings
RABBITMQ_HEARTBEAT=30
RABBITMQ_PREFETCH=10
RABBITMQ_CONNECTION_TIMEOUT=10000

# ==========================================
# Microservices Ports
# ==========================================
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003

# ==========================================
# Retry & Timeout Configuration
# ==========================================
# Maximum number of retry attempts
MAX_RETRY_ATTEMPTS=3

# Initial retry delay (milliseconds)
RETRY_INITIAL_DELAY=1000

# Maximum retry delay (milliseconds)
RETRY_MAX_DELAY=30000

# Backoff multiplier for exponential backoff
RETRY_BACKOFF_MULTIPLIER=2

# RPC timeout (milliseconds)
RPC_TIMEOUT=30000

# ==========================================
# Dead Letter Queue Configuration
# ==========================================
# Message TTL before moving to DLX (milliseconds)
DLQ_MESSAGE_TTL=60000

# ==========================================
# Application Environment
# ==========================================
NODE_ENV=development

# ==========================================
# MongoDB Configuration
# ==========================================
# MongoDB connection URI (with authentication)
MONGODB_URI=mongodb://localhost:27017

# MongoDB authentication
MONGODB_USER=erp_user
MONGODB_PASS=erp_password

# MongoDB database name
MONGODB_DB=open_erp

# MongoDB connection options
MONGODB_AUTH_SOURCE=admin
MONGODB_REPLICA_SET=
MONGODB_USE_TLS=false

# Connection pool settings
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# Timeouts (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_SOCKET_TIMEOUT=45000

# ==========================================
# Redis Configuration (for future use)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ==========================================
# JWT Configuration (for future use)
# ==========================================
# JWT_SECRET=your-secret-key
# JWT_EXPIRES_IN=3600

# ==========================================
# Email Configuration
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-password
AUTH_EMAIL_FROM=noreply@open-erp.com

# Verification token TTL in minutes (default: 15)
VERIFICATION_TOKEN_TTL=15

# Maximum verification attempts per time window (default: 3)
VERIFICATION_MAX_ATTEMPTS=3

# Rate limit window in milliseconds (default: 3600000 = 1 hour)
VERIFICATION_RATE_LIMIT_WINDOW=3600000

# Bypass email sending for testing (true/false)
VERIFICATION_EMAIL_BYPASS=false

# ==========================================
# SMS Configuration (for future use)
# ==========================================
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://api.sms-provider.com
