# ==========================================
# RabbitMQ Configuration
# ==========================================
# RabbitMQ connection URL (amqp://host:port or amqps://host:port)
RABBITMQ_URL=amqp://localhost:5672

# RabbitMQ authentication
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# Virtual host (default: /)
RABBITMQ_VHOST=/

# Connection settings
RABBITMQ_HEARTBEAT=30
RABBITMQ_PREFETCH=10
RABBITMQ_CONNECTION_TIMEOUT=10000

# ==========================================
# Microservices Ports
# ==========================================
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003

# ==========================================
# Retry & Timeout Configuration
# ==========================================
# Maximum number of retry attempts
MAX_RETRY_ATTEMPTS=3

# Initial retry delay (milliseconds)
RETRY_INITIAL_DELAY=1000

# Maximum retry delay (milliseconds)
RETRY_MAX_DELAY=30000

# Backoff multiplier for exponential backoff
RETRY_BACKOFF_MULTIPLIER=2

# RPC timeout (milliseconds)
RPC_TIMEOUT=30000

# ==========================================
# Dead Letter Queue Configuration
# ==========================================
# Message TTL before moving to DLX (milliseconds)
DLQ_MESSAGE_TTL=60000

# ==========================================
# Application Environment
# ==========================================
NODE_ENV=development

# ==========================================
# Database Configuration (for future use)
# ==========================================
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=open_erp

# ==========================================
# Redis Configuration (for future use)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ==========================================
# JWT Configuration (for future use)
# ==========================================
# JWT_SECRET=your-secret-key
# JWT_EXPIRES_IN=3600

# ==========================================
# Email Configuration (for future use)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password

# ==========================================
# SMS Configuration (for future use)
# ==========================================
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://api.sms-provider.com
