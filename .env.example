# ==========================================
# RabbitMQ Configuration
# ==========================================
# RabbitMQ connection URL (amqp://host:port or amqps://host:port)
RABBITMQ_URL=amqp://localhost:5672

# RabbitMQ authentication
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# Virtual host (default: /)
RABBITMQ_VHOST=/

# Connection settings
RABBITMQ_HEARTBEAT=30
RABBITMQ_PREFETCH=10
RABBITMQ_CONNECTION_TIMEOUT=10000

# ==========================================
# Microservices Ports
# ==========================================
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003
CONFIG_SERVICE_PORT=3004
ORGANIZATION_SERVICE_PORT=3005
INVENTORY_PORT=3005
COMMON_SERVICE_PORT=3006

# ==========================================
# Swagger/OpenAPI Configuration
# ==========================================
# Enable Swagger documentation for each service (true/false)
ENABLE_SWAGGER=true

# Docs aggregator service port
PORT=3000

# Service URLs for aggregator (JSON array)
# Format: [{"name": "Service Name", "url": "http://host:port/api-docs.json", "auth": {"type": "basic|bearer", "credentials": "..."}}]
# For Docker: use service names (auth-service, user-service, notification-service, config-service)
# For local: use localhost
SWAGGER_AGGREGATOR_SERVICES=[{"name":"Auth Service","url":"http://localhost:3001/api-docs.json"},{"name":"User Service","url":"http://localhost:3002/api-docs.json"},{"name":"Notification Service","url":"http://localhost:3003/api-docs.json"},{"name":"Config Service","url":"http://localhost:3004/api-docs.json"}]

# For Docker deployment, use:
# SWAGGER_AGGREGATOR_SERVICES=[{"name":"Auth Service","url":"http://auth-service:3001/api-docs.json"},{"name":"User Service","url":"http://user-service:3002/api-docs.json"},{"name":"Notification Service","url":"http://notification-service:3003/api-docs.json"},{"name":"Config Service","url":"http://config-service:3004/api-docs.json"},{"name":"Organization Service","url":"http://organization-service:3005/api-docs.json"}]

# ==========================================
# Retry & Timeout Configuration
# ==========================================
# Maximum number of retry attempts
MAX_RETRY_ATTEMPTS=3

# Initial retry delay (milliseconds)
RETRY_INITIAL_DELAY=1000

# Maximum retry delay (milliseconds)
RETRY_MAX_DELAY=30000

# Backoff multiplier for exponential backoff
RETRY_BACKOFF_MULTIPLIER=2

# RPC timeout (milliseconds)
RPC_TIMEOUT=30000

# ==========================================
# Dead Letter Queue Configuration
# ==========================================
# Message TTL before moving to DLX (milliseconds)
DLQ_MESSAGE_TTL=60000

# ==========================================
# Application Environment
# ==========================================
NODE_ENV=development

# ==========================================
# MongoDB Configuration
# ==========================================
# MongoDB connection URI (with authentication)
MONGODB_URI=mongodb://localhost:27017

# MongoDB authentication
MONGODB_USER=erp_user
MONGODB_PASS=erp_password

# MongoDB database name
MONGODB_DB=open_erp

# MongoDB connection options
MONGODB_AUTH_SOURCE=admin
MONGODB_REPLICA_SET=
MONGODB_USE_TLS=false

# Connection pool settings
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# Timeouts (milliseconds)
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_CONNECT_TIMEOUT=10000
MONGODB_SOCKET_TIMEOUT=45000

# ==========================================
# Redis Configuration (for future use)
# ==========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ==========================================
# JWT Configuration
# ==========================================
# JWT secret key for signing and verifying tokens (use a strong random string in production)
# This secret is also used for HMAC hashing of refresh tokens for secure storage
JWT_SECRET=your-secret-key-change-in-production

# Access token expiration time (e.g., 15m, 1h, 7d)
# Recommended: 15m-1h for better security
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token expiration time (e.g., 7d, 30d, 90d)
# Recommended: 7d-30d with automatic rotation on use
# Note: Refresh tokens are automatically rotated when used via POST /auth/refresh
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Email Configuration
# ==========================================
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=vernie.hand62@ethereal.email
SMTP_PASS=azqrWu8tQ31K3Yf8HU
AUTH_EMAIL_FROM=noreply@open-erp.com

# Verification token TTL in minutes (default: 15)
VERIFICATION_TOKEN_TTL=15

# Maximum verification attempts per time window (default: 3)
VERIFICATION_MAX_ATTEMPTS=3

# Rate limit window in milliseconds (default: 3600000 = 1 hour)
VERIFICATION_RATE_LIMIT_WINDOW=3600000

# Bypass email sending for testing (true/false)
VERIFICATION_EMAIL_BYPASS=false

# ==========================================
# Password Reset Configuration
# ==========================================
# Application base URL for building reset links
APP_URL=http://localhost:4200

# Reset token TTL in minutes (default: 15)
RESET_TOKEN_TTL=15

# Rate limit window for password reset requests in milliseconds (default: 60000 = 1 minute)
RESET_RATE_LIMIT_WINDOW=60000

# Maximum reset requests per time window (default: 1)
RESET_MAX_REQUESTS=1

# ==========================================
# SMS Configuration (for future use)
# ==========================================
# SMS_API_KEY=your-sms-api-key
# SMS_API_URL=https://api.sms-provider.com

# ==========================================
# Error Handling Configuration
# ==========================================
# Path to error registry JSON file (relative to project root)
ERROR_REGISTRY_PATH=libs/shared/errors/error-registry.json

# Default locale for error messages (en, vi, etc.)
ERROR_DEFAULT_LOCALE=en

# Base URL for error support documentation
ERROR_SUPPORT_BASE_URL=https://docs.open-erp.com

# ==========================================
# Organization Service Configuration
# ==========================================
# Invitation token expiry in days (default: 7)
INVITE_EXPIRY_DAYS=7

# Secret for invitation token generation (use a strong random string in production)
INVITE_SECRET=your-invite-secret-change-in-production

# Maximum invitations per organization per day (rate limiting)
MAX_INVITES_PER_DAY=50

# ==========================================
# SYSTEM ADMIN CREDENTIALS (for initial setup only)
# ==========================================
SYSTEM_ADMIN_EMAIL=admin@open-erp.com
SYSTEM_ADMIN_PASSWORD=Admin@12345
SYSTEM_ADMIN_NAME=System Administrator
