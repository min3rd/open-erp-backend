{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Single Resource Response Data",
  "description": "JSON Schema for validating single resource response data structure",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["get", "create", "update", "delete"],
      "description": "Operation mode"
    },
    "item": {
      "description": "Resource item (null for delete operations)"
    }
  },
  "if": {
    "properties": {
      "mode": { "const": "delete" }
    }
  },
  "then": {
    "properties": {
      "item": { "type": "null" }
    }
  }
}
