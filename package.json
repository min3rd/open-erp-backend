    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.10",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.11",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@turf/area": "^7.3.1",
    "@turf/bbox": "^7.3.1",
    "@turf/centroid": "^7.3.1",
