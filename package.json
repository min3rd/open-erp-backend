  "scripts": {
    "build": "nest build",
    "build:auth": "nest build auth",
    "build:user": "nest build user",
    "build:notification": "nest build notification",
    "build:config": "nest build config",
    "build:organization": "nest build organization",
    "build:inventory": "nest build inventory",
    "build:common": "nest build common",
    "build:all": "npm run build:auth && npm run build:user && npm run build:notification && npm run build:config && npm run build:organization && npm run build:inventory && npm run build:common",
    "format": "prettier --write \"src/**/*.ts\" \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:auth": "nest start auth",
    "start:auth:dev": "nest start auth --watch",
    "start:user": "nest start user",
    "start:user:dev": "nest start user --watch",
    "start:notification": "nest start notification",
    "start:notification:dev": "nest start notification --watch",
    "start:config": "nest start config",
    "start:config:dev": "nest start config --watch",
    "start:organization": "nest start organization",
    "start:organization:dev": "nest start organization --watch",
    "start:inventory": "nest start inventory",
    "start:inventory:dev": "nest start inventory --watch",
    "start:common": "nest start common",
    "start:common:dev": "nest start common --watch",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "migrate-mongo up",
    "db:migrate:down": "migrate-mongo down",
    "db:migrate:status": "migrate-mongo status",
    "db:seed:warehouse-types": "ts-node -r tsconfig-paths/register scripts/seeds/seed-warehouse-types.ts",
    "db:seed:all": "ts-node -r tsconfig-paths/register scripts/seeds/seed-all.ts",
    "db:seed:provinces": "ts-node -r tsconfig-paths/register scripts/seeds/seed-provinces.ts",
    "db:seed:wards": "ts-node -r tsconfig-paths/register scripts/seeds/seed-wards.ts",
    "db:seed:roles": "ts-node -r tsconfig-paths/register scripts/seeds/seed-roles.ts",
    "db:seed:organizations": "ts-node -r tsconfig-paths/register scripts/seeds/seed-organizations.ts",
    "db:seed:users": "ts-node -r tsconfig-paths/register scripts/seeds/seed-users.ts",
    "db:seed:warehouses": "ts-node -r tsconfig-paths/register scripts/seeds/seed-warehouses.ts",
    "db:seed:relations": "ts-node -r tsconfig-paths/register scripts/seeds/seed-relations.ts",
    "db:test": "node scripts/test-mongodb.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
